{
    "manifest_version": 3,
    "name": "AI-Based IDS Monitor",
    "version": "1.0.0",
    "description": "Real-time network intrusion detection monitoring extension",
    "author": "AI-Based IDS Team",
    "permissions": [
        "storage",
        "notifications",
        "alarms"
    ],
    "host_permissions": [
        "http://localhost:3000/*",
        "http://127.0.0.1:3000/*"
    ],
    "action": {
        "default_popup": "popup/popup.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        },
        "default_title": "AI-Based IDS Monitor"
    },
    "background": {
        "service_worker": "background/service-worker.js"
    },
    "options_page": "options/options.html",
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}