// Prisma schema for AI-Based Intrusion Detection System
// Prisma 7 puts the connection URL in prisma.config.ts and lib/prisma.ts.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model NetworkPacket {
  id         String   @id @default(cuid())
  timestamp  DateTime @default(now())
  sourceIP   String
  destIP     String
  sourcePort Int
  destPort   Int
  protocol   String
  packetSize Int
  flags      String?
  payload    String?

  detectionResult DetectionResult?

  createdAt DateTime @default(now())

  @@index([sourceIP])
  @@index([destIP])
  @@index([timestamp])
}

model DetectionResult {
  id              String   @id @default(cuid())
  timestamp       DateTime @default(now())
  isAnomaly       Boolean
  threatLevel     String
  attackType      String?
  confidence      Float
  detectionMethod String
  description     String
  recommendations String   @default("[]")
  modelScores     String   @default("{}")
  // JSON-encoded {source, destination, sourceFanout} entropy scores.
  ipEntropy       String   @default("{}")
  autoResponse    String?

  packetId String        @unique
  packet   NetworkPacket @relation(fields: [packetId], references: [id], onDelete: Cascade)

  humanLabel     String?
  humanLabelType String?
  reviewedAt     DateTime?

  createdAt DateTime @default(now())

  @@index([isAnomaly])
  @@index([threatLevel])
  @@index([timestamp])
}

model Alert {
  id         String   @id @default(cuid())
  timestamp  DateTime @default(now())
  severity   String
  title      String
  message    String
  sourceIP   String
  destIP     String
  attackType String
  status     String   @default("NEW")

  handledBy String?
  handledAt DateTime?
  notes     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([severity])
  @@index([timestamp])
}

model BlockedIP {
  id          String    @id @default(cuid())
  ipAddress   String    @unique
  reason      String
  attackType  String?
  confidence  Float     @default(0)
  blockedAt   DateTime  @default(now())
  expiresAt   DateTime?
  autoBlocked Boolean   @default(false)

  @@index([blockedAt])
}

model ModelMetrics {
  id                String   @id @default(cuid())
  method            String
  accuracy          Float
  precision         Float
  recall            Float
  f1Score           Float
  falsePositiveRate Float
  detectionTime     Float

  trainingSamples Int?
  testingSamples  Int?
  datasetUsed     String?

  recordedAt DateTime @default(now())

  @@index([method])
  @@index([recordedAt])
}

model SystemStats {
  id                   String   @id @default(cuid())
  timestamp            DateTime @default(now())
  totalPacketsAnalyzed Int
  anomaliesDetected    Int
  falsePositives       Int
  truePositives        Int
  packetsPerSecond     Float
  cpuUsage             Float
  memoryUsage          Float
  uptime               Int

  @@index([timestamp])
}

model AuditLog {
  id          String   @id @default(cuid())
  action      String
  entityType  String
  entityId    String?
  details     String?
  performedBy String?
  ipAddress   String?
  timestamp   DateTime @default(now())

  @@index([action])
  @@index([entityType])
  @@index([timestamp])
}
